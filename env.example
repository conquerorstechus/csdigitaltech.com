# Site configuration for sitemap generation
# Copy this file to .env.local and update with your actual domain
SITE_URL=https://www.conquerorstech.com
NEXT_PUBLIC_SITE_URL=https://www.conquerorstech.com

# Opinly configuration
OPINLY_API_KEY=
OPINLY_API_URL=https://api.opinly.ai
OPINLY_BLOG_PREFIX=/blog
OPINLY_IMAGES_PREFIX=/images
OPINLY_SITE_NAME=Cornerstone Digital Technologies
OPINLY_CATEGORY_PREFIX=category
OPINLY_AUTHOR_PREFIX=authors
OPINLY_TAG_PREFIX=tag

# You can change this to your actual domain when deploying
# SITE_URL=https://www.conquerorstech.com
